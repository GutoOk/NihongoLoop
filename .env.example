# Public frontend configuration
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Local worker-only runtime. Keep real values in an untracked .env.local or Secret Manager.
AI_WORKER_ONLY=false
AI_WORKER_GLOBAL_CONCURRENCY=8
AI_WORKER_USER_CONCURRENCY=4
AI_WORKER_PREPARE_SENTENCE_CONCURRENCY=3
AI_WORKER_TRANSLATE_CONCURRENCY=4
AI_WORKER_READING_CONCURRENCY=2
AI_WORKER_TERMS_CONCURRENCY=1
AI_WORKER_DICTIONARY_CONCURRENCY=1
AI_WORKER_POLL_MS=2000
AI_WORKER_LEASE_SECONDS=300
GEMINI_MODEL=gemini-2.5-flash-lite

# Private runtime values, intentionally blank here.
SUPABASE_SERVICE_ROLE_KEY=
GEMINI_API_KEY=
INTERNAL_HEALTH_TOKEN=

# Local tests only
ALLOW_AUTH_BYPASS=false
VITE_E2E_AUTH_BYPASS=false
VITE_E2E_DATA_MOCK=false
